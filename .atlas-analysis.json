  "keyFeatures": [
    "Real-time arbitrage detection across multiple bookmakers",
    "Expected value calculation with Pinnacle-based odds",
    "Multi-sport betting alerts via Telegram",
    "Automated bet grading and P&L tracking",
    "Blockchain betting integration (Optimism)",
    "Microservices architecture with MongoDB storage"
  ],
  "publicApiSurface": [
    "PropprTeamBot - Team market alerts (goals, corners, cards, shots)",
    "PropprPlayerBot - Player prop alerts (goals, assists, shots, passes)",
    "PropprEVBot - Expected value alerts with Kelly staking",
    "PropprArbBot - Arbitrage detection and stake calculation",
    "PropprHorseBot - Horse racing value detection",
    "OvertimeBot - Blockchain betting automation",
    "WebsocketUpdater - Real-time odds updates",
    "UnifiedAPIPoller - Multi-source data collection",
    "StatsUpdateFM - Player projections pipeline",
    "SharedServices.grading - Unified bet grading system",
    "SharedServices.mapping - Data normalization (leagues, markets)",
    "SharedServices.tracking - Bet tracking and reconstruction"
  ]
